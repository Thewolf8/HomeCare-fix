{
  "appId": "com.homecarecabinet.app",
  "appName": "HomeCare Cabinet",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#14b8a6",
      "sound": "beep.wav"
    },
    "Camera": {
      "quality": 80,
      "allowEditing": false,
      "resultType": "base64",
      "saveToGallery": false
    }
  },
  "android": {
    "buildOptions": {
      "keystorePath": null,
      "keystoreAlias": null,
      "keystorePassword": null,
      "keystoreAliasPassword": null,
      "releaseType": "APK"
    }
  }
}
